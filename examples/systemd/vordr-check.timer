# Runs vordr-check.service daily at 09:00. Per-user, reversible — see the .service
# file for install/remove commands. `Persistent=true` catches up if the machine was
# asleep at the scheduled time.

[Unit]
Description=Run vordr check daily

[Timer]
OnCalendar=*-*-* 09:00:00
Persistent=true

[Install]
WantedBy=timers.target
